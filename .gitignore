# --- Python -----------------------------------------------------------------
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# --- Node / frontend --------------------------------------------------------
node_modules/
frontend/dist/
frontend/node_modules/
frontend/.vite/
*.tsbuildinfo

# --- Project-specific runtime data (too large to track) --------------------
# workdir/ holds per-session uploads, previews, exports, caches
# models/ holds downloaded weight files (~hundreds of MB each)
# *.log catches uvicorn, pytest, ad-hoc logs
# tool-results/ is Claude Code prompt-cache spillover
workdir/
models/
*.log
tool-results/

# --- Secrets / local config (NEVER commit) ----------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# --- IDE / OS noise ---------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*~

# Claude Code transient runtime lock
.claude/scheduled_tasks.lock

# Local git worktrees (superpowers:using-git-worktrees fallback)
.worktrees/
.playwright-mcp/
